<controls:FancyWindow
    xmlns="https://spacestation14.io"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    Title="{Loc 'fax-machine-ui-page-window'}"
    MinSize="380 220">

    <BoxContainer Orientation="Vertical" HorizontalExpand="True" VerticalExpand="True">
        <PanelContainer StyleClasses="PanelDark" HorizontalExpand="True" VerticalExpand="True">
            <BoxContainer Orientation="Vertical" Margin="8">
                <BoxContainer Orientation="Horizontal">
                    <Label Text="{Loc 'fax-machine-ui-sending'}"
                           VerticalAlignment="Bottom"
                           HorizontalExpand="True" />

                    <Label Name="SendingLabel"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Align="Right"/>
                </BoxContainer>

                <BoxContainer Orientation="Horizontal">
                    <Label Text="{Loc 'fax-machine-ui-from'}"
                           VerticalAlignment="Bottom"
                           HorizontalExpand="True" />

                    <Label Name="FromLabel"
                           HorizontalAlignment="Right"
                           VerticalAlignment="Center"
                           Align="Right"/>
                </BoxContainer>

                <BoxContainer
                    Orientation="Horizontal">

                    <Label Text="{Loc 'fax-machine-ui-to'}"
                           VerticalAlignment="Bottom"
                           HorizontalExpand="True"/>

                    <BoxContainer Orientation="Horizontal">
                        <OptionButton Name="PeerSelector"
                                      StyleClasses="OpenRight" />

                        <Button StyleClasses="OpenLeft"
                                Name="RefreshButton"
                                ToolTip="{Loc 'fax-machine-ui-refresh-button'}">
                            <TextureButton
                                MouseFilter="Ignore"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Scale="0.9 0.9"
                                StyleClasses="RefreshButton" />
                        </Button>
                    </BoxContainer>
                </BoxContainer>
            </BoxContainer>
        </PanelContainer>
        <BoxContainer Orientation="Horizontal" SeparationOverride="8" Margin="8">
            <Button Name="SendButton"
                    Text="{Loc 'fax-machine-ui-send-button'}"
                    HorizontalExpand="True"
                    Disabled="True" />
        </BoxContainer>
    </BoxContainer>
</controls:FancyWindow>
